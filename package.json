{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "Implementação do tabnews para o curso.dev",
  "homepage": "https://github.com/pedrohgceolin/clone-tabnews#readme",
  "bugs": {
    "url": "https://github.com/pedrohgceolin/clone-tabnews/issues"
